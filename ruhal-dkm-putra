<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
/* ============================================================
   TOKEN SISTEM — ubah di sini untuk kustomisasi cepat
   ============================================================ */
:root{
  /* --- Warna --- */
  --ink:        #1E2E2A;   /* teks utama, gelap kehijauan spt ubin masjid lama */
  --ink-soft:   #4C5B55;   /* teks sekunder */
  --paper:      #F4F2EC;   /* latar utama, putih tulang hangat */
  --paper-alt:  #ECE8DD;   /* latar section alternatif */
  --gold:       #A8823D;   /* aksen tunggal — emas kuningan, dipakai hemat */
  --gold-soft:  #D8C9A3;   /* aksen lembut / hover */
  --line:       #D9D3C3;   /* garis pembatas tipis */
  --white:      #FFFFFF;

  /* --- Tipografi --- */
  --font-display: "Fraunces", Georgia, serif;
  --font-body:    "Inter", -apple-system, sans-serif;

  /* --- Layout --- */
  --maxw: 1120px;
  --radius: 2px;
  --transition: 420ms cubic-bezier(.65,0,.35,1);
}

*{box-sizing:border-box; margin:0; padding:0;}
html{scroll-behavior:smooth;}
body{
  font-family: var(--font-body);
  background: var(--paper);
  color: var(--ink);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
img{max-width:100%; display:block;}
a{color:inherit; text-decoration:none;}
ul{list-style:none;}
button{font-family:inherit; cursor:pointer;}

.wrap{
  max-width: var(--maxw);
  margin: 0 auto;
  padding: 0 32px;
}
.eyebrow{
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--gold);
}
.divider{
  width: 48px;
  height: 2px;
  background: var(--gold);
  margin: 18px 0 28px;
}

/* ============================================================
   NAVIGASI
   ============================================================ */
header{
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(244,242,236,.88);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--line);
}
.nav{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding: 20px 32px;
  max-width: var(--maxw);
  margin: 0 auto;
}
.brand{
  display:flex;
  align-items:center;
}
.brand img{
  height: 30px;
  width: auto;
  display:block;
}

.nav-links{
  display:flex;
  gap: 36px;
}
.nav-links a{
  font-size: 14px;
  font-weight: 500;
  color: var(--ink-soft);
  position: relative;
  padding: 4px 0;
  transition: color .25s ease;
}
.nav-links a::after{
  content:"";
  position:absolute;
  left:0; bottom:-2px;
  width:0; height:1px;
  background: var(--gold);
  transition: width .3s ease;
}
.nav-links a:hover, .nav-links a.active{ color: var(--ink); }
.nav-links a.active::after, .nav-links a:hover::after{ width:100%; }

.menu-btn{
  display:none;
  background:none;
  border:none;
  flex-direction:column;
  gap:5px;
}
.menu-btn span{
  width:22px; height:1.5px; background:var(--ink);
}

/* ============================================================
   PAGE SYSTEM (simulasi multi-page ala Framer)
   ============================================================ */
.page{ display:none; }
.page.active{ display:block; animation: fadeIn .5s ease; }
@keyframes fadeIn{
  from{ opacity:0; transform:translateY(8px); }
  to{ opacity:1; transform:translateY(0); }
}

/* ============================================================
   HERO — motif lengkung mihrab sebagai signature element
   ============================================================ */
.hero{
  position:relative;
  padding: 120px 32px 100px;
  text-align:center;
  overflow:hidden;
}
.hero-arch{
  position:absolute;
  top: -40px;
  left:50%;
  transform: translateX(-50%);
  width: min(640px, 90vw);
  opacity: .55;
  z-index:0;
  pointer-events:none;
}
.hero-inner{ position:relative; z-index:1; }
.hero .eyebrow{ justify-content:center; display:flex; }
.hero-logo{
  height: 34px;
  width: auto;
  margin: 0 auto;
  display: block;
}
.hero h1{
  font-family: var(--font-display);
  font-weight: 600;
  font-size: clamp(38px, 6vw, 68px);
  line-height: 1.08;
  letter-spacing: -.01em;
  margin: 22px auto 24px;
  max-width: 780px;
}
.hero p{
  max-width: 560px;
  margin: 0 auto;
  color: var(--ink-soft);
  font-size: 17px;
}
.hero .divider{ margin-left:auto; margin-right:auto; }

/* Kartu navigasi cepat di beranda */
.quick-links{
  display:grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
  margin: 64px 0 0;
}
.qcard{
  background: var(--paper);
  padding: 40px 32px;
  transition: background var(--transition);
}
.qcard:hover{ background: var(--white); }
.qcard .num{
  font-family: var(--font-display);
  font-size: 13px;
  color: var(--gold);
  letter-spacing: .1em;
}
.qcard h3{
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 500;
  margin: 14px 0 10px;
}
.qcard p{ font-size: 14px; color: var(--ink-soft); margin-bottom:18px; }
.qcard .go{
  font-size: 13px; font-weight:600; color: var(--ink);
  display:inline-flex; align-items:center; gap:6px;
}
.qcard .go svg{ transition: transform .3s ease; }
.qcard:hover .go svg{ transform: translateX(4px); }

/* ============================================================
   SECTION UMUM
   ============================================================ */
section.block{
  padding: 96px 32px;
}
.block-header{
  max-width: 640px;
  margin-bottom: 56px;
}
.block-header h2{
  font-family: var(--font-display);
  font-weight: 500;
  font-size: clamp(30px, 4vw, 42px);
  margin-top: 14px;
}
.block-header p{
  color: var(--ink-soft);
  margin-top: 16px;
  font-size: 16px;
}
.alt{ background: var(--paper-alt); }

/* ============================================================
   STRUKTUR ORGANISASI — frame foto dengan sudut bermotif
   ============================================================ */
.org-frame{
  position: relative;
  max-width: 820px;
  margin: 0 auto;
  padding: 28px;
}
.org-frame::before, .org-frame::after,
.org-frame .corner-tr, .org-frame .corner-br{
  content:"";
  position:absolute;
  width: 26px; height: 26px;
  border: 1.5px solid var(--gold);
}
.org-frame::before{ top:0; left:0; border-right:none; border-bottom:none; }
.org-frame::after{ bottom:0; left:0; border-right:none; border-top:none; }
.org-frame .corner-tr{ top:0; right:0; border-left:none; border-bottom:none; }
.org-frame .corner-br{ bottom:0; right:0; border-left:none; border-top:none; }

.org-photo{
  width:100%;
  aspect-ratio: 4 / 3;
  background:
    linear-gradient(135deg, var(--paper-alt) 25%, transparent 25%) -20px 0/40px 40px,
    linear-gradient(225deg, var(--paper-alt) 25%, transparent 25%) -20px 0/40px 40px,
    var(--white);
  border: 1px solid var(--line);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap: 10px;
  color: var(--ink-soft);
  text-align:center;
  padding: 24px;
}
.org-photo svg{ width:40px; height:40px; opacity:.5; }
.org-photo .label{ font-size:14px; font-weight:500; }
.org-photo .sub{ font-size:12px; max-width:280px; color:#8a8477; }
.org-photo img{
  width:100%; height:100%;
  object-fit: cover;
}

.role-list{
  max-width: 820px;
  margin: 56px auto 0;
  display:grid;
  grid-template-columns: repeat(3,1fr);
  border-top: 1px solid var(--line);
  border-left: 1px solid var(--line);
}
.role-item{
  border-right: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  padding: 24px;
}
.role-item .role{
  font-family: var(--font-display);
  font-size: 17px;
  font-weight:500;
}
.role-item .name{
  font-size: 13px;
  color: var(--ink-soft);
  margin-top: 6px;
}

/* ============================================================
   PROGRAM KERJA — tabel
   ============================================================ */
.tag{
  display:inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: var(--radius);
}
.tag.ruhal{ background: #E3E7DE; color: #45543C; }
.tag.dkm{ background: #EFE2C9; color: #7A5B22; }
.tag.koordinasi{ background: #E4E1EC; color: #4E4270; }
.tag.halaqah{ background: #DCE8EC; color: #2D5A66; }
.tag.dauroh{ background: #F0DCE0; color: #7A3548; }
.tag.skl{ background: #E8E2D3; color: #6B5A2E; }
.tag.phbi{ background: #EFE2C9; color: #7A5B22; }
.tag.masjid{ background: #E3E7DE; color: #45543C; }

.table-wrap{
  overflow-x: auto;
  border: 1px solid var(--line);
}
table{
  width:100%;
  border-collapse: collapse;
  min-width: 760px;
}
thead th{
  text-align:left;
  font-size: 12px;
  font-weight:600;
  letter-spacing:.08em;
  text-transform:uppercase;
  color: var(--ink-soft);
  padding: 16px 20px;
  background: var(--paper-alt);
  border-bottom: 1px solid var(--line);
  white-space:nowrap;
}
tbody td{
  padding: 18px 20px;
  border-bottom: 1px solid var(--line);
  font-size: 14.5px;
  vertical-align: top;
}
tbody tr:last-child td{ border-bottom:none; }
tbody tr{ transition: background .25s ease; }
tbody tr:hover{ background: rgba(168,130,61,.05); }
td.program{ font-weight:600; }
td.status{ white-space:nowrap; }
.status-dot{
  display:inline-flex; align-items:center; gap:7px;
  font-size:13px; color: var(--ink-soft);
}
.status-dot::before{
  content:""; width:7px; height:7px; border-radius:50%;
  background: var(--gold);
}

/* ============================================================
   GALERI KEGIATAN
   ============================================================ */
.gallery-intro{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  flex-wrap:wrap;
  gap:16px;
  margin-bottom: 64px;
}

/* --- Section per kegiatan --- */
.activity-section{
  margin-bottom: 88px;
}
.activity-section:last-child{ margin-bottom: 0; }
.activity-header{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  flex-wrap:wrap;
  gap: 16px;
  padding-bottom: 20px;
  margin-bottom: 28px;
  border-bottom: 1px solid var(--line);
}
.activity-header .meta{
  display:flex;
  align-items:center;
  gap: 12px;
  margin-bottom: 8px;
}
.activity-header .date{
  font-size: 12.5px;
  color: var(--ink-soft);
}
.activity-header h3{
  font-family: var(--font-display);
  font-weight: 500;
  font-size: clamp(21px, 2.6vw, 26px);
}
.activity-header p{
  font-size: 13.5px;
  color: var(--ink-soft);
  max-width: 440px;
}

.gallery-grid{
  display:grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.gitem{
  position:relative;
  overflow:hidden;
  background: var(--paper-alt);
  border: 1px solid var(--line);
  aspect-ratio: 1/1;
}
.gitem.tall{ aspect-ratio: 3/4; grid-row: span 1; }
.gitem .ph{
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
  color: var(--ink-soft);
}
.gitem img{
  position:absolute; inset:0;
  width:100%; height:100%;
  object-fit: cover;
}
.gitem .ph svg{ width:30px; height:30px; opacity:.4; }
.gitem .cap{
  position:absolute;
  left:0; right:0; bottom:0;
  padding: 16px;
  background: linear-gradient(to top, rgba(30,46,42,.82), transparent);
  color: var(--white);
  opacity:0;
  transform: translateY(8px);
  transition: all .35s ease;
}
.gitem:hover .cap{ opacity:1; transform:translateY(0); }
.gitem:hover .ph{ opacity: .25; }
.gitem .cap .t{ font-size:13.5px; font-weight:600; }
.gitem .cap .d{ font-size:11.5px; opacity:.8; margin-top:2px; }

/* ============================================================
   CATATAN KUSTOMISASI (terlihat hanya di kode)
   ============================================================ */
/* Untuk mengganti foto: ganti div class="org-photo" / class="ph" dengan
   <img src="foto-anda.jpg"> lalu hapus style placeholder-nya. */

/* ============================================================
   FOOTER
   ============================================================ */
footer{
  padding: 56px 32px 40px;
  border-top: 1px solid var(--line);
  text-align:center;
}
footer .brand{ justify-content:center; display:flex; margin-bottom:14px; }
footer .brand img{ height: 40px; }
footer p{ font-size:13px; color: var(--ink-soft); }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 860px){
  .quick-links{ grid-template-columns:1fr; }
  .role-list{ grid-template-columns: 1fr 1fr; }
  .gallery-grid{ grid-template-columns: repeat(3,1fr); }
}
@media (max-width: 720px){
  .nav-links{
    position:absolute;
    top:100%; left:0; right:0;
    flex-direction:column;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    padding: 16px 32px 24px;
    gap: 18px;
    display:none;
  }
  .nav-links.open{ display:flex; }
  .menu-btn{ display:flex; }
  .hero{ padding: 90px 24px 70px; }
  section.block{ padding: 64px 24px; }
  .role-list{ grid-template-columns: 1fr; }
}
@media (max-width: 560px){
  .gallery-grid{ grid-template-columns: 1fr 1fr; }
}
@media (prefers-reduced-motion: reduce){
  *{ animation:none !important; transition:none !important; }
}
</style>
</head>
